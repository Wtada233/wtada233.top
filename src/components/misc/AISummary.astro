--- 
export interface Props {
	content: string;
}

const { content } = Astro.props;

// 如果没有内容，不渲染组件
if (!content || content.trim() === "") {
	return null;
}
---

{content && (
  <div class="ai-summary">
    <div class="ai-title">
      <div class="ai-title-left">
        <img width="25" height="25" src="/gemini-color.png" alt="gemini-ai">
        <span class="ai-title-text">AI 摘要</span>
      </div>
      <div class="ai-tag">Gemini 2.5 Pro</div>
    </div>
    <div class="ai-explanation"></div>
  </div>
)}

<script is:inline define:vars={{ content }}>
  function runAITypingAnimation() {
    const textElement = document.querySelector('.ai-summary .ai-explanation');
    
    // Exit if conditions are not met
    if (!textElement || !content || !window.location.pathname.includes('/posts/')) {
      return;
    }

    // Prevent re-initialization
    if (textElement.hasAttribute('data-ai-typing-initialized')) {
        return;
    }
    textElement.setAttribute('data-ai-typing-initialized', 'true');

    textElement.textContent = '';
    textElement.classList.remove('typing-complete');
    
    let index = 0;
    const typeSpeed = 30; // ms
    
    let typeWriterTimeout;
    
    function typeWriter() {
      // Race condition safety check: If element is no longer in the DOM, stop everything.
      if (!document.body.contains(textElement)) {
        clearTimeout(typeWriterTimeout);
        return;
      }

      if (index < content.length) {
        textElement.textContent += content.charAt(index);
        index++;
        typeWriterTimeout = setTimeout(typeWriter, typeSpeed);
      } else {
        textElement.classList.add('typing-complete');
      }
    }
    
    // Delay to start typing for dramatic effect
    const startTypingTimeout = setTimeout(typeWriter, 800);

    // Proper cleanup for Astro's View Transitions.
    // This listener is added on each page load and automatically removed after the next swap.
    document.addEventListener('astro:before-swap', () => {
      clearTimeout(startTypingTimeout);
      clearTimeout(typeWriterTimeout);
    }, { once: true });
  }

  // Run on initial page load and on subsequent page transitions
  runAITypingAnimation(); // Also run for the very first page load
</script>
