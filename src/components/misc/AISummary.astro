--- 
export interface Props {
	content: string;
}

const { content } = Astro.props;

// 如果没有内容，不渲染组件
if (!content || content.trim() === "") {
	return null;
}
---

{content && (
  <div class="ai-summary">
    <div class="ai-title">
      <div class="ai-title-left">
        <img width="25" height="25" src="/gemini-color.png" alt="gemini-ai">
        <span class="ai-title-text">AI 摘要</span>
      </div>
      <div class="ai-tag">Gemini 2.5 Pro</div>
    </div>
    <div class="ai-explanation"></div>
  </div>
)}

<script define:vars={{ content }}>
  function initAITyping() {
    // Only run on post pages
    if (!window.location.pathname.includes('/posts/')) {
      return;
    }

    // Since this script is tied to this component, we can be more specific.
    // This assumes only one AI summary per page.
    const textElement = document.querySelector('.ai-summary .ai-explanation');
    
    if (!textElement) {
      return;
    }

    // Check if already initialized
    if (textElement.hasAttribute('data-initialized')) {
      return;
    }

    // The 'content' variable is now directly available from `define:vars`
    if (!content) {
      return;
    }

    // Mark as initialized
    textElement.setAttribute('data-initialized', 'true');
    textElement.textContent = '';
    textElement.classList.remove('typing-complete');
    
    let index = 0;
    const typeSpeed = 30; // ms
    
    function typeWriter() {
      if (index < content.length) {
        textElement.textContent += content.charAt(index);
        index++;
        setTimeout(typeWriter, typeSpeed);
      } else {
        textElement.classList.add('typing-complete');
      }
    }
    
    // Delay to start typing for dramatic effect
    setTimeout(typeWriter, 800);
  }

  // Run on initial page load and subsequent navigations
  document.addEventListener('astro:page-load', initAITyping);
  // Also run immediately in case astro:page-load was missed (e.g., initial non-transitioned load)
  initAITyping();
</script>
